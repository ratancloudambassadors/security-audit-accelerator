generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  email          String    @unique
  passwordHash   String
  name           String?
  displayPicture String?
  createdAt      DateTime  @default(now())
  isVerified     Boolean   @default(false)
  otp            String?
  otpExpiry      DateTime?
  
  projects       Project[]
  schedules      AuditSchedule[]
}

model Project {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  provider    String   // e.g., 'gcp', 'aws', 'azure'
  credentials String?  // Stored credentials for automation (JSON string)
  createdAt   DateTime @default(now())
  
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  scans     ScanHistory[]
  schedules AuditSchedule[]
}

model ScanHistory {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  score            Float
  scannedResources Int
  criticalCount    Int
  highCount        Int
  mediumCount      Int
  findings         String   // Stored as JSON string to accommodate large payloads
  createdAt        DateTime @default(now())
  
  projectId        String   @db.ObjectId
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model AuditSchedule {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  frequency   String   // 'daily', 'weekly', 'monthly', 'once'
  time        String?  // HH:mm format
  daysOfWeek  String[] // ["Monday", "Wednesday"]
  dayOfMonth  Int?     // 1 to 31
  credentials String?  // Stored credentials specifically for this schedule (JSON string)
  lastRun     DateTime?
  nextRun     DateTime
  targetEmail String?  // Optional target address for automation report overriding default user
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectId String?  @db.ObjectId // Optional if they provided new credentials
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
